---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { DEFAULT_LOCALE } from "@/i18n/locales";
import { getLocalizedPageId } from "@/utils/contentLocale";
import { getSharedLocaleAlternates } from "@/utils/localeAlternates";
import { getLocalizedSiteTitle } from "@/utils/siteMeta";

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const about = await getEntry("pages", getLocalizedPageId("about", locale));
const siteTitle = getLocalizedSiteTitle(locale);

if (!about) {
  throw new Error(
    "Missing content entry: `about.md` or `about.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(about);
---

<Layout
  title={`${about.data.title} | ${siteTitle}`}
  description={about.data.description}
  ogImage={about.data.ogImage}
  canonicalURL={about.data.canonicalURL}
  localeAlternates={getSharedLocaleAlternates("about")}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={about.data.title} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
