---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { DEFAULT_LOCALE } from "@/i18n/locales";
import { getSharedLocaleAlternates } from "@/utils/localeAlternates";
import { getHomePosts, HOME_POSTS_PER_LOAD } from "@/utils/homePostFeed";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
const sortedPosts = await getHomePosts(locale);
const homepagePosts = sortedPosts.slice(0, HOME_POSTS_PER_LOAD);
const hasMorePosts = sortedPosts.length > homepagePosts.length;
const homePath = getRelativeLocaleUrl(locale, "");
const feedBasePath = getRelativeLocaleUrl(locale, "post-feed/");
---

<Layout localeAlternates={getSharedLocaleAlternates("")}>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    {
      homepagePosts.length > 0 && (
        <section id="home-posts" class="py-8">
          <h1 class="sr-only">{t.pages.postsTitle}</h1>
          <masonry-layout
            id="home-post-grid"
            role="list"
            gap="20"
            maxcolwidth="420"
            data-feed-base={feedBasePath}
            data-next-page="2"
            data-has-more={hasMorePosts}
            data-locale={locale}
            data-timezone={config.site.timezone}
            data-updated-label={t.post.updatedAt}
          >
            {homepagePosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </masonry-layout>
          <div id="home-post-sentinel" aria-live="polite" />
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  import "@appnest/masonry-layout";

  type HomePost = {
    title: string;
    description: string;
    url: string;
    pubDatetime: string;
    modDatetime: string | null;
    timezone: string | undefined;
  };

  type MasonryLayoutElement = HTMLElement & { layout?: () => void };

  function createCard(
    post: HomePost,
    grid: MasonryLayoutElement
  ): HTMLLIElement {
    const item = document.createElement("li");
    item.className =
      "border-border bg-surface/60 hover:bg-surface-hover/80 rounded-lg border p-4 transition-colors";

    const link = document.createElement("a");
    link.href = post.url;
    link.className =
      "text-foreground hover:text-accent inline-block text-lg font-semibold tracking-tight underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0";

    const heading = document.createElement("h3");
    heading.textContent = post.title;
    link.append(heading);

    const datetime = grid
      .querySelector<HTMLElement>("li > div")
      ?.cloneNode(true) as HTMLElement | undefined;
    const date = new Date(post.modDatetime ?? post.pubDatetime);
    const isModified = Boolean(
      post.modDatetime &&
      new Date(post.modDatetime) > new Date(post.pubDatetime)
    );

    if (datetime) {
      const label = datetime.querySelector("span");
      if (!isModified) label?.remove();
      if (isModified && !label) {
        const updatedLabel = document.createElement("span");
        updatedLabel.className = "text-sm";
        updatedLabel.textContent = `${grid.dataset.updatedLabel}:`;
        datetime.querySelector("time")?.before(updatedLabel);
      }

      const time = datetime.querySelector("time");
      if (time) {
        time.dateTime = date.toISOString();
        time.textContent = new Intl.DateTimeFormat(grid.dataset.locale, {
          year: "numeric",
          month: "short",
          day: "numeric",
          timeZone: post.timezone ?? grid.dataset.timezone,
        }).format(date);
      }
    }

    const description = document.createElement("p");
    description.className = "text-muted-foreground mt-2 leading-7";
    description.textContent = post.description;

    item.append(link);
    if (datetime) item.append(datetime);
    item.append(description);
    return item;
  }

  function setupInfinitePosts() {
    const grid =
      document.querySelector<MasonryLayoutElement>("#home-post-grid");
    const sentinel = document.querySelector("#home-post-sentinel");
    if (!grid || !sentinel || grid.dataset.hasMore !== "true") return;

    let nextPage = Number(grid.dataset.nextPage);
    let isLoading = false;
    let lastLoadScrollY = -1;

    const loadNextPage = async () => {
      if (isLoading || !nextPage) return;
      isLoading = true;

      try {
        const response = await fetch(
          `${grid.dataset.feedBase}${nextPage}.json`
        );
        if (!response.ok) throw new Error("Unable to load more posts");

        const feed = (await response.json()) as {
          posts: HomePost[];
          hasMore: boolean;
        };
        grid.append(...feed.posts.map(post => createCard(post, grid)));
        grid.layout?.();

        if (feed.hasMore) {
          nextPage += 1;
        } else {
          nextPage = 0;
          observer.disconnect();
        }
      } catch {
        sentinel.textContent = "";
      } finally {
        isLoading = false;
      }
    };

    const observer = new IntersectionObserver(
      entries => {
        if (
          entries.some(entry => entry.isIntersecting) &&
          window.scrollY > lastLoadScrollY
        ) {
          lastLoadScrollY = window.scrollY;
          void loadNextPage();
        }
      },
      { rootMargin: "0px" }
    );

    observer.observe(sentinel);
  }

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    setupInfinitePosts();
  });
</script>

<style>
  :global(#home-post-grid > li) {
    margin: 0.5rem;
    list-style: none;
  }

  :global(#home-post-grid > li > a) {
    font-size: 1rem;
  }
</style>
