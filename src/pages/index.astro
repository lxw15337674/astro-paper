---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { DEFAULT_LOCALE } from "@/i18n/locales";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { filterCollectionByLocale } from "@/utils/contentLocale";
import { getSharedLocaleAlternates } from "@/utils/localeAlternates";
import { getLocalizedRssPath } from "@/utils/localeMeta";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);

const posts = filterCollectionByLocale(await getCollection("posts"), locale);
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout localeAlternates={getSharedLocaleAlternates("")}>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border/80 border-b pt-10 pb-8">
      <h1
        class="my-4 inline-block text-4xl leading-tight font-semibold tracking-tight sm:my-8 sm:text-5xl"
      >
        {t.home.heroTitle}
      </h1>
      <a
        target="_blank"
        href={getLocalizedRssPath(locale)}
        class="inline-block"
        aria-label={t.a11y.rssFeed}
        title={t.a11y.rssFeed}
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">{t.a11y.rssFeed}</span>
      </a>

      <p class="text-muted-foreground leading-7">{t.home.intro}</p>
      <p class="text-muted-foreground mt-2 leading-7">
        {t.home.introCtaPrefix}
        {" "}
        <LinkButton
          class="text-accent hover:text-accent-active underline underline-offset-4"
          href="https://github.com/satnaing/astro-paper#readme"
        >
          {t.home.introCtaLabel}
        </LinkButton>
        {" "}
        {t.home.introCtaSuffix}
      </p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border/80 border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-tight">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-tight">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton
        href={getRelativeLocaleUrl(locale, "posts")}
        class="border-border bg-surface hover:bg-surface-hover text-foreground px-3 py-2 text-sm font-medium"
      >
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
