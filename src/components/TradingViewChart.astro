---
type WidgetKind = "advanced-chart" | "symbol-overview" | "asia-overview";

type Props = {
  kind: WidgetKind;
  title: string;
  caption: string;
};

const { kind, title, caption } = Astro.props;

const isAdvancedChart = kind === "advanced-chart";
const isAsiaOverview = kind === "asia-overview";
const scriptSrc = isAdvancedChart
  ? "https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js"
  : "https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js";

const options = isAdvancedChart
  ? {
      autosize: true,
      symbol: "BINANCE:BTCUSDT",
      interval: "D",
      timezone: "Asia/Shanghai",
      theme: "dark",
      style: "1",
      locale: "zh_CN",
      allow_symbol_change: false,
      calendar: false,
      support_host: "https://www.tradingview.com",
    }
  : isAsiaOverview
    ? {
        symbols: [
          ["上证", "SSE:000001|1D"],
          ["深成", "SZSE:399001|1D"],
          ["创业板", "SZSE:399006|1D"],
          ["恒生", "HSI:HSI|1D"],
          ["国企", "HSI:HSCEI|1D"],
          ["恒科", "HSI:HSTECH|1D"],
        ],
        chartOnly: false,
        width: "100%",
        height: "100%",
        locale: "zh_CN",
        colorTheme: "dark",
        autosize: true,
        showVolume: true,
        showMA: false,
        hideDateRanges: false,
        hideMarketStatus: false,
        hideSymbolLogo: false,
        scalePosition: "right",
        scaleMode: "Normal",
        fontFamily: "inherit",
        fontSize: "10",
        noTimeScale: false,
        valuesTracking: "1",
        changeMode: "price-and-percent",
        chartType: "area",
        maLineColor: "#2962FF",
        maLineWidth: 1,
        maLength: 9,
        headerFontSize: "medium",
        lineWidth: 2,
        lineType: 0,
        dateRanges: ["1d|1", "1m|30", "3m|60", "12m|1D", "60m|1W"],
      }
    : {
        symbols: [
          ["SPY", "AMEX:SPY|1D"],
          ["QQQ", "NASDAQ:QQQ|1D"],
          ["DIA", "AMEX:DIA|1D"],
        ],
        chartOnly: false,
        width: "100%",
        height: "100%",
        locale: "zh_CN",
        colorTheme: "dark",
        autosize: true,
        showVolume: true,
        showMA: false,
        hideDateRanges: false,
        hideMarketStatus: false,
        hideSymbolLogo: false,
        scalePosition: "right",
        scaleMode: "Normal",
        fontFamily: "inherit",
        fontSize: "10",
        noTimeScale: false,
        valuesTracking: "1",
        changeMode: "price-and-percent",
        chartType: "area",
        maLineColor: "#2962FF",
        maLineWidth: 1,
        maLength: 9,
        headerFontSize: "medium",
        lineWidth: 2,
        lineType: 0,
        dateRanges: ["1d|1", "1m|30", "3m|60", "12m|1D", "60m|1W"],
      };
---

<section class="tv-chart not-prose" aria-label={title}>
  <div class="tv-chart__header">
    <div>
      <div class="tv-chart__title" role="heading" aria-level="2">{title}</div>
      <p>{caption}</p>
    </div>
    <a
      href="https://www.tradingview.com/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Open TradingView"
    >
      TradingView
    </a>
  </div>

  <div
    class:list={[
      "tv-chart__frame",
      { "tv-chart__frame--advanced": isAdvancedChart },
    ]}
  >
    <div class="tradingview-widget-container">
      <div class="tradingview-widget-container__widget"></div>
      <script
        type="text/javascript"
        src={scriptSrc}
        async
        is:inline
        set:html={JSON.stringify(options)}
      />
    </div>
  </div>
</section>

<style>
  .tv-chart {
    margin-block: 2rem;
    border: 1px solid color-mix(in srgb, var(--border), transparent 8%);
    border-radius: 0.5rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface), transparent 0%),
        color-mix(in srgb, var(--surface-hover), transparent 24%)
      ),
      var(--surface);
    box-shadow: 0 18px 45px color-mix(in srgb, #000, transparent 90%);
    overflow: hidden;
  }

  .tv-chart__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 0.875rem;
    border-bottom: 1px solid var(--border);
  }

  .tv-chart__title {
    margin: 0;
    color: var(--foreground);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .tv-chart__header p {
    margin: 0.25rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .tv-chart__header a {
    color: var(--muted-foreground);
    font-size: 0.72rem;
    line-height: 1.4;
    text-decoration: none;
    white-space: nowrap;
  }

  .tv-chart__header a:hover,
  .tv-chart__header a:focus-visible {
    color: var(--accent);
  }

  .tv-chart__frame {
    height: clamp(360px, 62vw, 520px);
    background: #131722;
  }

  .tv-chart__frame--advanced {
    height: clamp(420px, 70vw, 640px);
  }

  .tradingview-widget-container,
  .tradingview-widget-container__widget {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 640px) {
    .tv-chart {
      margin-inline: calc(var(--spacing-app-inline, 1rem) * -0.25);
      border-inline: 0;
      border-radius: 0;
    }

    .tv-chart__header {
      flex-direction: column;
      gap: 0.35rem;
    }

    .tv-chart__frame,
    .tv-chart__frame--advanced {
      height: 430px;
    }
  }
</style>
